<?xml version="1.0" encoding="utf-8"?>
<!--
   Data extraction rules for Neko Music
   See https://developer.android.com/about/versions/12/backup-restore#xml-changes
   for details.
-->
<data-extraction-rules>
    <cloud-backup>
        <!-- 备份用户数据库（播放列表、搜索历史等） -->
        <include domain="database" path="app_database"/>

        <!-- 备份非敏感设置，排除登录凭据、搜索历史、缓存记录和更新状态 -->
        <include domain="sharedpref" path="."/>
        <exclude domain="sharedpref" path="user_prefs.xml"/>
        <exclude domain="sharedpref" path="search_history.xml"/>
        <exclude domain="sharedpref" path="search_state.xml"/>
        <exclude domain="sharedpref" path="music_cache.xml"/>
        <exclude domain="sharedpref" path="app_update.xml"/>
        <exclude domain="sharedpref" path="privacy_consent.xml"/>

        <!-- 备份内部存储中的用户数据文件 -->
        <include domain="file" path="playlists/"/>
        <include domain="file" path="user_data/"/>
    </cloud-backup>

    <device-transfer>
        <!-- 设备传输时备份更多数据 -->
        <!-- 备份所有数据库 -->
        <include domain="database" path="."/>

        <!-- 备份非敏感 SharedPreferences -->
        <include domain="sharedpref" path="."/>
        <exclude domain="sharedpref" path="user_prefs.xml"/>
        <exclude domain="sharedpref" path="search_history.xml"/>
        <exclude domain="sharedpref" path="search_state.xml"/>
        <exclude domain="sharedpref" path="music_cache.xml"/>
        <exclude domain="sharedpref" path="app_update.xml"/>
        <exclude domain="sharedpref" path="privacy_consent.xml"/>

        <!-- 备份内部存储中的所有用户数据 -->
        <include domain="file" path="playlists/"/>
        <include domain="file" path="user_data/"/>
        <include domain="file" path="settings/"/>
    </device-transfer>
</data-extraction-rules>
