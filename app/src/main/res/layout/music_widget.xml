<?xml version="1.0" encoding="utf-8"?>
<!-- 尽量用系统主题属性 + 框架 Material 横条；不确定进度时由 Provider 打开 indeterminate（系统流动动画） -->
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/widget_root"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:padding="16dp"
    android:background="?android:attr/colorBackground">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:layout_marginBottom="12dp">

        <ImageView
            android:id="@+id/widget_cover"
            android:layout_width="64dp"
            android:layout_height="64dp"
            android:layout_marginEnd="12dp"
            android:src="@drawable/music"
            android:scaleType="centerCrop"
            android:background="@android:color/darker_gray" />

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical">

            <TextView
                android:id="@+id/widget_song_title"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Neko云音乐"
                android:textAppearance="?android:attr/textAppearanceMedium"
                android:textColor="?android:attr/textColorPrimary"
                android:textStyle="bold"
                android:maxLines="1"
                android:ellipsize="end" />

            <TextView
                android:id="@+id/widget_artist_name"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="暂无播放"
                android:textAppearance="?android:attr/textAppearanceSmall"
                android:textColor="?android:attr/textColorSecondary"
                android:maxLines="1"
                android:ellipsize="end"
                android:layout_marginTop="4dp" />
        </LinearLayout>
    </LinearLayout>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:layout_marginBottom="12dp">

        <TextView
            android:id="@+id/widget_current_time"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="0:00"
            android:textAppearance="?android:attr/textAppearanceSmall"
            android:textColor="?android:attr/textColorSecondary"
            android:layout_marginEnd="8dp" />

        <ProgressBar
            android:id="@+id/widget_progress_bar"
            style="@android:style/Widget.Material.ProgressBar.Horizontal"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:minHeight="8dp"
            android:max="100"
            android:progress="0" />

        <TextView
            android:id="@+id/widget_total_time"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="0:00"
            android:textAppearance="?android:attr/textAppearanceSmall"
            android:textColor="?android:attr/textColorSecondary"
            android:layout_marginStart="8dp" />
    </LinearLayout>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center">

        <ImageButton
            android:id="@+id/widget_previous"
            android:layout_width="44dp"
            android:layout_height="44dp"
            android:src="@drawable/previous_song"
            android:background="?android:attr/selectableItemBackgroundBorderless"
            android:contentDescription="@string/widget_previous_desc"
            android:scaleType="centerInside"
            android:padding="10dp"
            android:tint="?android:attr/colorControlNormal" />

        <ImageButton
            android:id="@+id/widget_play_pause"
            android:layout_width="52dp"
            android:layout_height="52dp"
            android:src="@drawable/play"
            android:background="?android:attr/selectableItemBackgroundBorderless"
            android:contentDescription="@string/widget_play_pause_desc"
            android:scaleType="centerInside"
            android:layout_marginStart="16dp"
            android:layout_marginEnd="16dp"
            android:padding="12dp"
            android:tint="?android:attr/colorControlActivated" />

        <ImageButton
            android:id="@+id/widget_next"
            android:layout_width="44dp"
            android:layout_height="44dp"
            android:src="@drawable/next_song"
            android:background="?android:attr/selectableItemBackgroundBorderless"
            android:contentDescription="@string/widget_next_desc"
            android:scaleType="centerInside"
            android:padding="10dp"
            android:tint="?android:attr/colorControlNormal" />
    </LinearLayout>
</LinearLayout>
